generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password_hash    String
  full_name        String?
  first_name       String?
  last_name        String?
  position         String?
  role             String   @default("viewer")
  managed_team_ids String[]
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
}

model Team {
  id          String   @id @default(uuid())
  name        String
  color       String?
  description String?
  lead_id     String?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}

model TeamMember {
  id                   String   @id @default(uuid())
  team_id              String
  name                 String
  discipline           String
  availability_percent Int      @default(100)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt
}

model WorkAreaType {
  id         String   @id @default(uuid())
  name       String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model WorkArea {
  id                  String    @id @default(uuid())
  name                String
  color               String?
  type                String?
  leading_team_id     String?
  supporting_team_ids String[]
  prod_id             String?
  jira_key            String?
  jira_status         String?
  jira_progress       Int?
  last_synced         DateTime?
  linked_epic_keys    String[]
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt
}

model Sprint {
  id                     String    @id @default(uuid())
  team_id                String?
  name                   String
  quarter                String
  start_date             DateTime?
  end_date               DateTime?
  is_cross_team          Boolean   @default(false)
  is_template            Boolean   @default(false)
  relevant_work_area_ids String[]
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
}

model Allocation {
  id             String   @id @default(uuid())
  sprint_id      String
  team_member_id String
  work_area_id   String
  percent        Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model QuarterlyAllocation {
  id             String   @id @default(uuid())
  quarter        String
  team_member_id String
  work_area_id   String
  percent        Int
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt
}

model QuarterlyWorkAreaSelection {
  id            String   @id @default(uuid())
  quarter       String
  team_id       String
  work_area_ids String[]
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model QuarterlyPlanHistory {
  id                String    @id @default(uuid())
  quarter           String
  team_id           String?
  team_name         String?
  team_member_id    String?
  member_name       String?
  member_discipline String?
  work_area_id      String?
  work_area_name    String?
  work_area_type    String?
  action            String?
  old_percent       Int?
  new_percent       Int?
  changed_at        DateTime?
  created_at        DateTime  @default(now())
}

model QuarterlyPlanSnapshot {
  id               String   @id @default(uuid())
  quarter          String
  team_id          String
  team_name        String?
  label            String
  note             String?
  created_by_email String?
  created_at       DateTime @default(now())
  allocations      Json
}

model JiraSyncHistory {
  id             String   @id @default(uuid())
  timestamp      DateTime @default(now())
  jql            String?
  result_summary Json?
  created_at     DateTime @default(now())
}
